<!-- MAIN INSTALL ENGINE -->
<FILE Run="/bin/bash">
<INLINE>
#!/bin/bash
# AICliAgents Modular Installer Engine
export NAME="unraid-aicliagents"
export VERSION="2026.04.16.27"
export GIT_URL="https://raw.githubusercontent.com/johnpwhite/unraid-plg-aicliagents/main"
export EMHTTP_DEST="/usr/local/emhttp/plugins/unraid-aicliagents"
export CONFIG_DIR="/boot/config/plugins/unraid-aicliagents"

# --- I/O Setup (FD 1 = Log, FD 3 = Progress, FD 4 = UI) ---
# D-194: Redirect original STDOUT to FD 4 before redirecting FD 1 to log file
exec 4&gt;&amp;1

# D-347: Detection of Upgrade vs Fresh Install
export UPGRADE_MODE="0"
if [ -d "$EMHTTP_DEST" ] || [ -f "/var/log/plugins/$NAME.plg" ]; then
    export UPGRADE_MODE="1"
fi

# D-230: Define authoritative logging helpers (Aligned with LogService.php)
get_ts() { date '+%Y-%m-%d %H:%M:%S'; }
log_status() { echo "$1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] INFO: $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_step()   { echo "" &gt;&amp;4 2&gt;/dev/null; echo "  [>] $1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] INFO:   [>] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_ok()     { echo "  [OK] $1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] INFO:   [OK] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_warn()   { echo "  [!!] $1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] WARN:   [!!] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_fail()   { echo "  [FAIL] $1" &gt;&amp;4 2&gt;/dev/null; echo "[$(get_ts)] [AICliAgents] ERROR:   [FAIL] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
log_progress() { echo "PROGRESS: $1" &gt;&amp;3 2&gt;/dev/null; }

export -f log_status log_step log_ok log_warn log_fail log_progress get_ts

chmod +x /tmp/aicli-*.sh

mkdir -p /tmp/unraid-aicliagents "$CONFIG_DIR"
LOG_FILE="$CONFIG_DIR/install.log"
export LOG_FILE

# Clear old log and start with a header
echo "[$(get_ts)] [AICliAgents] INFO: --- AICliAgents Installation Log (v$VERSION) ---" &gt; "$LOG_FILE"

# --- Modular Engine Bootstrap ---
# We run the engine in a subshell and pipe its entire output (traces/errors) 
# into a timestamp formatter for the log file.
if [ -f "/tmp/aicli-engine.sh" ]; then
    (
        set -x
        bash /tmp/aicli-engine.sh
    ) 2&gt;&amp;1 | while read -r line; do
        # If it's a progress signal, send to FD 3
        if [[ "$line" == PROGRESS:* ]]; then
            echo "$line" &gt;&amp;3 2&gt;/dev/null
        # D-291: Standard Timestamp Regex [YYYY-MM-DD HH:MM:SS]
        elif [[ "$line" =~ ^\[[0-9]{4}-[0-9]{2}-[0-9]{2}\ [0-9]{2}:[0-9]{2}:[0-9]{2}\] ]]; then
            echo "$line" &gt;&gt; "$LOG_FILE"
        else
            echo "[$(get_ts)] [AICliAgents] INFO: $line" &gt;&gt; "$LOG_FILE"
        fi
    done
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        log_fail "Modular Engine execution failed. Aborting installation."
        exit 1
    fi
else
    log_fail "Installer Engine (aicli-engine.sh) missing from /tmp. Aborting."
    exit 1
fi

# Phase 6: Storage Migration (Background)
# D-308: Moved OUTSIDE subshell/pipe to prevent installer hang.
# Full detachment ensured with &lt; /dev/null
if [ -f /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/installer/migrate-btrfs-to-squashfs.sh ]; then
    log_status "Initiating background storage migration (Btrfs -&gt; SquashFS)..."
    mkdir -p /tmp/unraid-aicliagents
    touch /tmp/unraid-aicliagents/migration.lock
    nohup bash /usr/local/emhttp/plugins/unraid-aicliagents/src/scripts/installer/migrate-btrfs-to-squashfs.sh &gt; /tmp/unraid-aicliagents/migration.log 2&gt;&amp;1 &lt; /dev/null &amp;
    disown
fi

# Cleanup installer scripts from /tmp
rm -f /tmp/aicli-*.sh

</INLINE>
</FILE>

<!-- UNINSTALL ENGINE -->
<FILE Method="remove" Run="/bin/bash">
<INLINE>
#!/bin/bash
NAME="unraid-aicliagents"
CONFIG_DIR="/boot/config/plugins/$NAME"
EMHTTP_DEST="/usr/local/emhttp/plugins/$NAME"

# 1. Setup Logging &amp; Status
# We log to USB for persistence during uninstall
LOG_FILE="$CONFIG_DIR/uninstall.log"
exec 3&gt;&amp;1
exec &gt; "$LOG_FILE" 2&gt;&amp;1
set -x

log_status() { echo "$1" &gt;&amp;3; }
export -f log_status

log_status "--- AICliAgents Uninstall Start ---"

# 1.A PERSISTENCE PHASE (MANDATORY for Upgrades)
# D-341: Ensure all ZRAM-backed user homes are persisted before we kill the processes.
# D-344: Architecture-Aware Persistence. We check for new TaskService first, then fallback to legacy procedural sync.
log_status "Persisting active user states from RAM/ZRAM to Flash..."
if [ -f "$EMHTTP_DEST/src/includes/AICliAgentsManager.php" ]; then
    for user_mnt in /tmp/unraid-aicliagents/work/*/home; do
        if mountpoint -q "$user_mnt"; then
            user=$(basename "$(dirname "$user_mnt")")
            log_status "  > Detected active SquashFS home for $user..."
            
            # 1. Check for TaskService (Modern 2026.04+)
            if grep -q "TaskService" "$EMHTTP_DEST/src/includes/AICliAgentsManager.php"; then
                log_status "    > Using TaskService::persistHome..."
                /usr/bin/php -r "require_once '$EMHTTP_DEST/src/includes/AICliAgentsManager.php'; \AICliAgents\Services\TaskService::persistHome('$user', true);" &gt; /dev/null 2&gt;&amp;1
            
            # 2. Check for legacy procedural sync (Early 2026)
            elif grep -q "function aicli_sync_home" "$EMHTTP_DEST/src/includes/AICliAgentsManager.php"; then
                log_status "    > Using legacy aicli_sync_home..."
                /usr/bin/php -r "require_once '$EMHTTP_DEST/src/includes/AICliAgentsManager.php'; aicli_sync_home('$user');" &gt; /dev/null 2&gt;&amp;1
            fi
        fi
    done
fi

# D-345: Legacy IMG Persistence (Era 2)
# If legacy .img files are mounted, they are Btrfs loop mounts and typically 
# handled by 'umount', but we ensure any known RAM shims are flushed if applicable.
# (Most Era 2 plugins synced on every write, but we perform a safety sync)
if mount | grep -q "aicliagents.*\.img"; then
    log_status "  > Flushing legacy Btrfs loop mounts..."
    sync
fi

# 2. Kill Active Processes &amp; Runtime Files
# We call the modular script for the heavy lifting of process killing
UNINSTALL_SCRIPT="$EMHTTP_DEST/scripts/uninstaller/cleanup.sh"
if [ -f "$UNINSTALL_SCRIPT" ]; then
    export NAME EMHTTP_DEST CONFIG_DIR
    bash "$UNINSTALL_SCRIPT"
else
    # Fallback if script missing
    log_status "Cleaning up active processes..."
    pgrep -f "ttyd.*(aicliterm|geminiterm)-" | xargs kill -9 &gt; /dev/null 2&gt;&amp;1 || true
    if command -v tmux &gt;/dev/null 2&gt;&amp;1; then
        tmux ls -F '#S' 2&gt;/dev/null | grep -E "^aicli-agent-" | xargs -I {} tmux kill-session -t "{}" &gt; /dev/null 2&gt;&amp;1 || true
    fi
    pgrep -f "node.*(aicli|gemini).mjs" | xargs kill -9 &gt; /dev/null 2&gt;&amp;1 || true
fi

# MANDATORY: Clear stale installation states and runtime logs
rm -rf /tmp/unraid-aicliagents

# 3. Prune USB Artifacts (pkg-cache removal as requested)
if [ -d "$CONFIG_DIR" ]; then
    log_status "Pruning USB artifacts..."
    rm -f "$CONFIG_DIR/aicli.mjs"
    rm -f "$CONFIG_DIR/debug.log"
    rm -f "$CONFIG_DIR/versions.json"
    rm -f "$CONFIG_DIR/tmux"
    rm -f "$CONFIG_DIR"/*.tar.gz
    rm -f "$CONFIG_DIR"/*.tar.xz
    rm -f "$CONFIG_DIR"/*.gz
    # MANDATORY: Remove agent package caches
    rm -rf "$CONFIG_DIR/pkg-cache"
fi

# 4. Forced emhttp removal (Ensures tab disappears)
if [ -d "$EMHTTP_DEST" ]; then
    log_status "Removing plugin files from emhttp..."
    rm -f /usr/local/bin/aicli-repair
    rm -rf "$EMHTTP_DEST"
fi

# 5. Final PLG clean
rm -f /var/log/plugins/${NAME}.plg

log_status " "
log_status "==========================================================="
log_status "                UNINSTALL COMPLETE                        "
log_status "==========================================================="
log_status " "
log_status "  [DONE] Binaries and UI files removed"
log_status "  [DONE] Runtime processes terminated"
log_status "  [DONE] Agent package caches pruned"
log_status " "
log_status "  [NOTE] YOUR SETTINGS HAVE BEEN PRESERVED:"
log_status "  > Config:     $CONFIG_DIR/*.cfg"
log_status "  > Persistence: $CONFIG_DIR/persistence/"
log_status " "
log_status "  [LOGS] Detailed uninstall trace preserved at:"
log_status "  > $LOG_FILE"
log_status " "
log_status "  [TIP] To fully remove all data, manually delete:"
log_status "  > rm -rf $CONFIG_DIR"
log_status "==========================================================="

echo "Uninstall of $NAME complete."
exit 0
</INLINE>
</FILE>

</PLUGIN>
