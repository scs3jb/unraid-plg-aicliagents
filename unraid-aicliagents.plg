<!-- MAIN INSTALL ENGINE -->
<FILE Run="/bin/bash">
<INLINE>
#!/bin/bash
# AICliAgents Modular Installer Engine
export NAME="unraid-aicliagents"
export VERSION="2026.04.06.54"
export GIT_URL="https://raw.githubusercontent.com/johnpwhite/unraid-plg-aicliagents/main"
export EMHTTP_DEST="/usr/local/emhttp/plugins/unraid-aicliagents"
export CONFIG_DIR="/boot/config/plugins/unraid-aicliagents"

# --- I/O Setup ---
# FD 3 is the Unraid plugin manager's display channel.
# All user-visible status goes to FD 3; verbose trace goes to the log file.
# --- I/O Setup (FD 1 = Log, FD 3 = Progress) ---
status() { echo "$1" &gt;&amp;4; echo "[$(date +%T)] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
step()   { echo "" &gt;&amp;4; echo "  [>] $1" &gt;&amp;4; echo "[$(date +%T)]   [>] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
ok()     { echo "  [OK] $1" &gt;&amp;4; echo "[$(date +%T)]   [OK] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
warn()   { echo "  [!!] $1" &gt;&amp;4; echo "[$(date +%T)]   [!!] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
fail()   { echo "  [FAIL] $1" &gt;&amp;4; echo "[$(date +%T)]   [FAIL] $1" &gt;&gt; "$LOG_FILE" 2&gt;/dev/null; }
progress() { echo "PROGRESS: $1" &gt;&amp;3; }
export -f status step ok warn fail progress

chmod +x /tmp/aicli-*.sh

mkdir -p /tmp/unraid-aicliagents "$CONFIG_DIR"
LOG_FILE="/tmp/unraid-aicliagents/install.log"
exec 4&gt;&amp;1
exec &gt; "$LOG_FILE" 2&gt;&amp;1
set -x

# --- Upgrade vs Fresh Install Detection ---
if [ -f "/var/log/plugins/${NAME}.plg" ]; then
    export UPGRADE_MODE=1
    INSTALL_MODE_LABEL="UPGRADE"
else
    export UPGRADE_MODE=0
    INSTALL_MODE_LABEL="FRESH INSTALL"
fi

status " "
status "================================================================="
status "  AI CLI AGENTS  v$VERSION"
status "  Mode: $INSTALL_MODE_LABEL"
status "  Log:  $LOG_FILE"
status "  Press ^C to abort."
status "================================================================="
progress "10"

# -----------------------------------------------------------------
#  [1/5]  SYSTEM PREPARATION
# -----------------------------------------------------------------
status " "
status "  [1/5] System Preparation"
status "-----------------------------------------------------------------"
mkdir -p "$EMHTTP_DEST/scripts/user"
mv /tmp/aicli-repair.sh "$EMHTTP_DEST/scripts/user/repair-plugin.sh"
mv /tmp/aicli-stop.sh "$EMHTTP_DEST/scripts/user/stop-plugin.sh"
mv /tmp/aicli-stop-warning.page "$EMHTTP_DEST/ArrayStopWarning.page"
ok "Manifest deployed. Directories ready."

# -----------------------------------------------------------------
#  [2/5]  PERSISTENT STORAGE (Btrfs)
# -----------------------------------------------------------------
progress "20"
status " "
status "  [2/5] Persistent Storage (Btrfs)"
status "-----------------------------------------------------------------"
bash /tmp/aicli-storage.sh

# -----------------------------------------------------------------
#  [3/5]  LEGACY CLEANUP &amp; SESSION BACKUP
# -----------------------------------------------------------------
progress "40"
status " "
status "  [3/5] Legacy Cleanup &amp; Session Backup"
status "-----------------------------------------------------------------"
bash /tmp/aicli-clean.sh
bash /tmp/aicli-legacy.sh

# -----------------------------------------------------------------
#  [4/5]  RUNTIME DEPENDENCIES
# -----------------------------------------------------------------
progress "70"
status " "
status "  [4/5] Runtime Dependencies (Node, tmux, fd, rg)"
status "-----------------------------------------------------------------"
bash /tmp/aicli-runtime.sh

# -----------------------------------------------------------------
#  [5/5]  UI ASSETS &amp; FINALIZATION
# -----------------------------------------------------------------
progress "90"
status " "
status "  [5/5] UI Assets &amp; Finalization"
status "-----------------------------------------------------------------"
bash /tmp/aicli-ui.sh

# Deploy Btrfs service to persistent emhttp location
mkdir -p "/usr/local/emhttp/plugins/unraid-aicliagents/scripts"
cp /tmp/aicli-btrfs.sh "/usr/local/emhttp/plugins/unraid-aicliagents/scripts/btrfs_delta_service.sh"
chmod +x "/usr/local/emhttp/plugins/unraid-aicliagents/scripts/btrfs_delta_service.sh"
bash /tmp/aicli-finalize.sh

progress "100"
status " "
status "================================================================="
status "  [OK] INSTALLATION COMPLETE  --  v$VERSION"
status "  Full log: $LOG_FILE"
status "================================================================="
status " "

# Cleanup installer scripts from /tmp
rm -f /tmp/aicli-*.sh
</INLINE>
</FILE>

<!-- UNINSTALL ENGINE -->
<FILE Method="remove" Run="/bin/bash">
<INLINE>
#!/bin/bash
NAME="unraid-aicliagents"
CONFIG_DIR="/boot/config/plugins/$NAME"
EMHTTP_DEST="/usr/local/emhttp/plugins/$NAME"

# 1. Setup Logging &amp; Status
# We log to USB for persistence during uninstall
LOG_FILE="$CONFIG_DIR/uninstall.log"
exec 3&gt;&amp;1
exec &gt; "$LOG_FILE" 2&gt;&amp;1
set -x

status() { echo "$1" &gt;&amp;3; }
export -f status

status "--- AICliAgents Uninstall Start ---"

# 2. Kill Active Processes &amp; Runtime Files
# We call the modular script for the heavy lifting of process killing
UNINSTALL_SCRIPT="$EMHTTP_DEST/scripts/uninstaller/cleanup.sh"
if [ -f "$UNINSTALL_SCRIPT" ]; then
    export NAME EMHTTP_DEST CONFIG_DIR
    bash "$UNINSTALL_SCRIPT"
else
    # Fallback if script missing
    status "Cleaning up active processes..."
    pgrep -f "ttyd.*(aicliterm|geminiterm)-" | xargs kill -9 &gt; /dev/null 2&gt;&amp;1 || true
    if command -v tmux &gt;/dev/null 2&gt;&amp;1; then
        tmux ls -F '#S' 2&gt;/dev/null | grep -E "^aicli-agent-" | xargs -I {} tmux kill-session -t "{}" &gt; /dev/null 2&gt;&amp;1 || true
    fi
    pgrep -f "node.*(aicli|gemini).mjs" | xargs kill -9 &gt; /dev/null 2&gt;&amp;1 || true
fi

# MANDATORY: Clear stale installation states and runtime logs
rm -rf /tmp/unraid-aicliagents

# 3. Prune USB Artifacts (pkg-cache removal as requested)
if [ -d "$CONFIG_DIR" ]; then
    status "Pruning USB artifacts..."
    rm -f "$CONFIG_DIR/aicli.mjs"
    rm -f "$CONFIG_DIR/debug.log"
    rm -f "$CONFIG_DIR/versions.json"
    rm -f "$CONFIG_DIR/tmux"
    rm -f "$CONFIG_DIR"/*.tar.gz
    rm -f "$CONFIG_DIR"/*.tar.xz
    rm -f "$CONFIG_DIR"/*.gz
    # MANDATORY: Remove agent package caches
    rm -rf "$CONFIG_DIR/pkg-cache"
fi

# 4. Forced emhttp removal (Ensures tab disappears)
if [ -d "$EMHTTP_DEST" ]; then
    status "Removing plugin files from emhttp..."
    rm -f /usr/local/bin/aicli-repair
    rm -rf "$EMHTTP_DEST"
fi
rm -f /tmp/aicli-btrfs.sh

# 5. Final PLG clean
rm -f /var/log/plugins/${NAME}.plg

status " "
status "==========================================================="
status "                UNINSTALL COMPLETE                        "
status "==========================================================="
status " "
status "  [DONE] Binaries and UI files removed"
status "  [DONE] Runtime processes terminated"
status "  [DONE] Agent package caches pruned"
status " "
status "  [NOTE] YOUR SETTINGS HAVE BEEN PRESERVED:"
status "  > Config:     $CONFIG_DIR/*.cfg"
status "  > Persistence: $CONFIG_DIR/persistence/"
status " "
status "  [LOGS] Detailed uninstall trace preserved at:"
status "  > $LOG_FILE"
status " "
status "  [TIP] To fully remove all data, manually delete:"
status "  > rm -rf $CONFIG_DIR"
status "==========================================================="

echo "Uninstall of $NAME complete."
exit 0
</INLINE>
</FILE>

</PLUGIN>
