<script>
// Use the PHP-parsed aicli_csrf token as the primary source of truth
window.csrf_token = window.csrf_token || '<?=$csrf_token?>';

function getCsrf() {
    return window.csrf_token || (typeof csrf_token !== 'undefined' ? csrf_token : '');
}

var aicli_csrf = getCsrf();
var progressTimers = {};
var activeInstalls = new Set();
var isUnloading = false;
window.addEventListener('beforeunload', function() { isUnloading = true; });

$(function() {
    if ($.isFunction($.fn.fileTreeAttach)) {
        $('input[data-pickroot]').fileTreeAttach(null, null, function(path) {
            $(document).trigger('close.fileTree');
            $(this).trigger('change');
        });
    }
});

function openCreateUserModal() { window.open('/Users/UserAdd', '_blank'); }

function refreshUserList() {
    aicli_csrf = getCsrf();
    fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=get_users&csrf_token=' + encodeURIComponent(aicli_csrf))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.status === 'ok' && data.users) {
                const select = document.getElementById('user_select');
                const currentVal = select.value;
                select.innerHTML = '';
                Object.entries(data.users).forEach(function(pair) {
                    const u = pair[0];
                    const d = pair[1];
                    const opt = document.createElement('option');
                    opt.value = u;
                    opt.innerText = u + (d && u !== d ? ' (' + d + ')' : "");
                    select.appendChild(opt);
                });
                select.value = currentVal;
                onUserChange(currentVal);
            }
        });
}

function onUserChange(username) {
    const ramDisplay = document.getElementById('display_ram_dir');
    const homeInput = document.getElementById('home_path');
    const homeDisplay = document.getElementById('display_home_path');
    if (ramDisplay) ramDisplay.innerText = '/tmp/unraid-aicliagents/work/' + username;
    if (homeInput) homeInput.value = '/boot/config/plugins/unraid-aicliagents/persistence/' + username + '/home';
    if (homeDisplay) homeDisplay.innerText = '/boot/config/plugins/unraid-aicliagents/persistence/' + username + '/home';
}

function checkUpdates() {
    if (activeInstalls.size > 0) return;
    const btn = document.getElementById('btn-check-updates');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-circle-o-notch fa-spin"></i> Checking...';
    aicli_csrf = getCsrf();
    fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=check_updates&csrf_token=' + encodeURIComponent(aicli_csrf))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-refresh"></i> Check for Updates';
            if (data.status === 'ok' && data.updates) {
                Object.entries(data.updates).forEach(function(pair) {
                    const id = pair[0];
                    const info = pair[1];
                    const status = document.getElementById('status-' + id);
                    if (status && info.has_update) {
                        let updateDiv = document.getElementById('update-status-' + id);
                        if (!updateDiv) {
                            updateDiv = document.createElement('div');
                            updateDiv.id = 'update-status-' + id;
                            updateDiv.className = 'agent-status update';
                            updateDiv.style.marginTop = '1px';
                            status.parentNode.insertBefore(updateDiv, status.nextSibling);
                        }
                        updateDiv.innerHTML = '<i class="fa fa-arrow-circle-up"></i> Update Available (' + info.latest_version + ')';
                    }
                });
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-refresh"></i> Check for Updates';
        });
}

function viewDebugLog() {
    aicli_csrf = getCsrf();
    fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=get_log&csrf_token=' + encodeURIComponent(aicli_csrf))
        .then(function(r) { return r.text(); })
        .then(function(text) {
            if (typeof swal === 'function') {
                swal({ title: "Debug Log", text: text || "Log is empty.", customClass: "swal-wide" });
            }
        });
}

function manualSyncHome() {
    aicli_csrf = getCsrf();
    const btn = event.currentTarget;
    const originalHtml = btn.innerHTML;
    if (typeof swal === 'function') {
        swal({ title: "Syncing...", text: "Please wait...", type: "info", showConfirmButton: false });
    }
    btn.disabled = true;
    btn.innerHTML = 'Syncing...';
    fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=sync_home&csrf_token=' + encodeURIComponent(aicli_csrf))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            if (data.status === 'ok') {
                swal({ title: "Sync Successful", type: "success" });
            } else {
                swal("Sync Failed", "Error syncing to flash.", "error");
            }
        });
}

function clearLog() {
    swal({ 
        title: "Clear Log?", 
        type: "warning", 
        showCancelButton: true,
        showLoaderOnConfirm: true,
        closeOnConfirm: false
    }, function() {
        aicli_csrf = getCsrf();
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=clear_log&csrf_token=' + encodeURIComponent(aicli_csrf))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.status === 'ok') {
                    swal("Cleared", "The debug log has been emptied.", "success");
                } else {
                    swal("Error", data.message || "Failed to clear log.", "error");
                }
            })
            .catch(function() {
                swal("Error", "Network error occurred while clearing log.", "error");
            });
    });
}

function repairAgentStorage(btn = null) {
    swal({ 
        title: "Repair Agent Storage?", 
        text: "This will attempt to fix mount issues and Btrfs metadata mismatches. This is recommended if agents appear missing after a reboot.", 
        type: "warning", 
        showCancelButton: true,
        showLoaderOnConfirm: true,
        closeOnConfirm: false
    }, function(isConfirm) {
        if (!isConfirm) return;
        const csrf = getCsrf();
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=repair_agent_storage&csrf_token=' + encodeURIComponent(csrf))
            .then(function(r) { return r.json(); })
            .then(function(data) { 
                if (data.status === 'ok') {
                    swal("Repair Successful", data.message || "Storage remounted.", "success");
                } else {
                    swal("Repair Failed", data.message || "An error occurred during repair.", "error");
                }
                refreshStorageStatus(); 
            })
            .catch(function() {
                swal("Error", "Network error occurred while repairing storage.", "error");
            });
    });
}

function repairHomeStorage(user, btn = null) {
    swal({ 
        title: "Repair Home Storage?", 
        text: "This will attempt to rescue the home image for '" + user + "' if it has become stuck in Read-Only mode. Existing data will be preserved.", 
        type: "warning", 
        showCancelButton: true,
        showLoaderOnConfirm: true,
        closeOnConfirm: false
    }, function(isConfirm) {
        if (!isConfirm) return;
        const csrf = getCsrf();
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=repair_home_storage&user=' + encodeURIComponent(user) + '&csrf_token=' + encodeURIComponent(csrf))
            .then(function(r) { return r.json(); })
            .then(function(data) { 
                if (data.status === 'ok') {
                    swal("Repair Successful", data.message || "Home storage remounted RW.", "success");
                } else {
                    swal("Repair Failed", data.message || "An error occurred during rescue.", "error");
                }
                refreshStorageStatus(); 
            })
            .catch(function() {
                swal("Error", "Network error occurred while repairing storage.", "error");
            });
    });
}

function pollInstallStatus(agentId) {
    aicli_csrf = getCsrf();
    fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=get_install_status&agentId=' + agentId + '&csrf_token=' + encodeURIComponent(aicli_csrf))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            const textEl = document.getElementById('text-' + agentId);
            const barEl = document.getElementById('bar-' + agentId);
            const statusEl = document.getElementById('status-' + agentId);
            const btnInstall = document.getElementById('btn-install-' + agentId);
            const btnUpgrade = document.getElementById('btn-upgrade-' + agentId);
            if (data.message) {
                if (textEl) textEl.innerText = data.message;
                if (barEl) barEl.style.width = data.progress + '%';
            }
            if (data.progress >= 100) {
                clearInterval(progressTimers[agentId]);
                delete progressTimers[agentId];
                activeInstalls.delete(agentId);
                if (statusEl) statusEl.className = 'agent-status installed';
                if (activeInstalls.size === 0) setTimeout(function() { window.location.reload(); }, 2000);
            } else if (data.message && data.message.indexOf('Error:') !== -1) {
                clearInterval(progressTimers[agentId]);
                delete progressTimers[agentId];
                activeInstalls.delete(agentId);
                if (btnInstall) btnInstall.disabled = false;
                if (btnUpgrade) btnUpgrade.disabled = false;
                swal("Failed", data.message, "error");
            }
        });
}

function installAgent(agentId, isUpgrade = false, btn = null) {
    if (activeInstalls.has(agentId)) return;
    if (isUpgrade) {
        swal({ title: "Upgrade?", text: "Upgrade " + agentId, type: "info", showCancelButton: true }, function(confirmed) {
            if (confirmed) performAgentInstall(agentId, isUpgrade, btn);
        });
    } else {
        performAgentInstall(agentId, isUpgrade, btn);
    }
}

function performAgentInstall(agentId, isUpgrade, btn) {
    const status = document.getElementById('status-' + agentId);
    const progress = document.getElementById('progress-' + agentId);
    const bar = document.getElementById('bar-' + agentId);
    if (btn) btn.disabled = true;
    progress.style.display = 'block';
    bar.style.width = '2%';
    aicli_csrf = getCsrf();
    fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=install_agent&agentId=' + agentId + '&csrf_token=' + encodeURIComponent(aicli_csrf))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.status === 'ok') {
                progressTimers[agentId] = setInterval(function() { pollInstallStatus(agentId); }, 800);
            } else {
                activeInstalls.delete(agentId);
                if (btn) btn.disabled = false;
                swal("Failed", data.message || data.error, "error");
            }
        });
}

function uninstallAgent(agentId, btn = null) {
    swal({ title: "Uninstall?", type: "warning", showCancelButton: true }, function(confirmed) {
        if (confirmed) {
            activeInstalls.add(agentId);
            if (btn) btn.disabled = true;
            aicli_csrf = getCsrf();
            fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=uninstall_agent&agentId=' + agentId + '&csrf_token=' + encodeURIComponent(aicli_csrf))
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.status === 'ok') window.location.reload();
                    else { activeInstalls.delete(agentId); btn.disabled = false; swal("Failed", "error"); }
                });
        }
    });
}

function saveAICliAgentsManager(form, silent = false) {
    const formData = new FormData(form);
    const params = new URLSearchParams();
    for (const pair of formData.entries()) { params.set(pair[0], pair[1]); }
    aicli_csrf = getCsrf() || formData.get('csrf_token') || '';
    params.set('csrf_token', aicli_csrf);
    document.querySelectorAll('input[name^="preview_"], input[name^="node_memory_"]').forEach(function(el) {
        params.set(el.name, el.type === 'checkbox' ? (el.checked ? "1" : "0") : el.value);
    });
    fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=save&csrf_token=' + encodeURIComponent(aicli_csrf), {
        method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: params.toString()
    }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.status === 'ok') window.location.reload();
    });
}

document.addEventListener('DOMContentLoaded', function() {
    aicli_csrf = getCsrf();
    document.querySelectorAll('.agent-actions').forEach(function(container) {
        const id = container.id.replace('actions-', '');
        if (!id) return;
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=get_install_status&agentId=' + id + '&csrf_token=' + encodeURIComponent(aicli_csrf))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data && data.progress > 0 && data.progress < 100) {
                    activeInstalls.add(id);
                    document.getElementById('progress-' + id).style.display = 'block';
                    progressTimers[id] = setInterval(function() { pollInstallStatus(id); }, 800);
                }
            });
    });
    setTimeout(checkUpdates, 1000);
    setTimeout(refreshStorageStatus, 500);
});

function executeStorageMigration() {
    const current = '<?=$config['persistence_base']?>';
    const newPath = document.getElementById('new_storage_path').value;
    const csrf = getCsrf();
    swal({ title: "Migrate?", type: "warning", showCancelButton: true }, function() {
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=migrate_storage&path=' + encodeURIComponent(newPath) + '&csrf_token=' + encodeURIComponent(csrf))
            .then(function(r) { return r.json(); }).then(function(data) { window.location.reload(); });
    });
}

function executeRepair() {
    swal({ title: "Repair?", type: "warning", showCancelButton: true }, function(confirmed) {
        if (!confirmed) return;
        const csrf = getCsrf();
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=repair_plugin&csrf_token=' + encodeURIComponent(csrf))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.status === 'ok') {
                    swal({ title: "Repairing...", text: '<div id="repair-msg">Initializing...</div><div id="repair-bar" style="width:5%; height:10px; background:#ff8c00;"></div>', html: true, showConfirmButton: false });
                    const poller = setInterval(function() {
                        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=get_repair_status&csrf_token=' + encodeURIComponent(csrf))
                            .then(function(r) { return r.json(); })
                            .then(function(status) {
                                document.getElementById('repair-bar').style.width = status.progress + '%';
                                document.getElementById('repair-msg').innerText = status.message;
                                if (status.progress >= 100) { clearInterval(poller); window.location.reload(); }
                            });
                    }, 1000);
                }
            });
    });
}

function executeAgentStorageMigration() {
    const current = '<?=$config['agent_storage_path'] ?? '/boot/config/plugins/unraid-aicliagents'?>';
    const newPath = document.getElementById('agent_storage_path').value;
    const csrf = getCsrf();
    swal({ title: "Migrate Agents?", type: "warning", showCancelButton: true }, function() {
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=migrate_agent_storage&path=' + encodeURIComponent(newPath) + '&csrf_token=' + encodeURIComponent(csrf))
            .then(function(r) { return r.json(); }).then(function(data) { window.location.reload(); });
    });
}

function toggleMigrateBtn(inputId, btnId, originalValue) {
    const input = document.getElementById(inputId);
    const btn = document.getElementById(btnId);
    btn.disabled = (input.value === originalValue || input.value === '');
}

function refreshStorageStatus() {
    const csrf = getCsrf();
    fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=get_storage_status&csrf_token=' + encodeURIComponent(csrf))
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.status === 'mounted') {
                document.getElementById('storage-status-loading').style.display = 'none';
                document.getElementById('storage-status-active').style.display = 'flex';
                document.getElementById('storage-usage-text').innerText = data.used_mb + 'MB / ' + data.total_mb + 'MB';
                document.getElementById('storage-usage-bar').style.width = Math.min(100, Math.round((data.used_mb / data.total_mb) * 100)) + '%';
                
                // D-160: Show Read-Only / Read-Write label
                const roLabel = document.getElementById('storage-ro-label');
                if (roLabel) {
                    if (data.is_read_only) {
                        roLabel.innerText = 'READ-ONLY';
                        roLabel.style.background = '#3a87ad';
                        roLabel.style.display = 'inline-block';
                    } else if (data.write_protect_agents) {
                        roLabel.innerText = 'READ-WRITE';
                        roLabel.style.background = '#86b32d';
                        roLabel.style.display = 'inline-block';
                    } else {
                        roLabel.style.display = 'none';
                    }
                }

                // D-170: Update Rootfs (RAM Disk) usage
                const rootfsText = document.getElementById('rootfs-usage-text');
                if (rootfsText) {
                    rootfsText.innerText = data.rootfs_usage_percent + '% Used (' + data.rootfs_free_mb + 'MB Free)';
                }
                const rootfsBar = document.getElementById('rootfs-usage-bar');
                if (rootfsBar) {
                    rootfsBar.style.width = data.rootfs_usage_percent + '%';
                    // Dynamic coloring based on usage
                    if (data.rootfs_usage_percent > 85) rootfsBar.style.background = '#f87171';
                    else if (data.rootfs_usage_percent > 60) rootfsBar.style.background = '#fbbf24';
                    else rootfsBar.style.background = '#34d399';
                }
                const rootfsWarn = document.getElementById('rootfs-warn-icon');
                if (rootfsWarn) {
                    rootfsWarn.style.display = data.rootfs_warning ? 'inline-block' : 'none';
                }

                if (data.home_stats) {
                    let html = '';
                    for (const user in data.home_stats) {
                        const s = data.home_stats[user];
                        const pct = Math.min(100, Math.round((s.used_mb / s.total_mb) * 100));
                        html += '<div class="aicli-info-row" style="margin-top: 10px;">' +
                                '<div class="aicli-info-label">Home: ' + user + '</div>' +
                                '<div class="aicli-info-value" style="flex-direction: column; align-items: flex-start; gap: 4px;">' +
                                    '<div style="display:flex; justify-content:space-between; align-items:center; width:100%;">' +
                                        '<code>' + s.used_mb + 'MB / ' + s.total_mb + 'MB</code>' +
                                        '<div class="aicli-info-btns">' +
                                            '<span onclick="repairHomeStorage(\'' + user + '\', this)" class="aicli-pill-btn warning" title="Repair Home: Fix mount issues if storage becomes Read-Only">Repair</span>' +
                                            '<span onclick="shrinkStorage(\'home_' + user + '\', this)" class="aicli-pill-btn danger" title="Optimize storage: Shrink to minimum safe size">Shrink</span>' +
                                            '<span onclick="expandStorage(\'home_' + user + '\', null, this)" class="aicli-pill-btn" title="Increase image size by 128MB">+128MB</span>' +
                                        '</div>' +
                                    '</div>' +
                                    '<div style="height:6px; background:#333; border-radius:3px; overflow:hidden; width:100%;">' +
                                        '<div style="height:100%; width:' + pct + '%; background:#86b32d; transition: width 0.4s ease;"></div>' +
                                    '</div>' +
                                '</div>' +
                            '</div>';
                    }
                    document.getElementById('home_storage_container').innerHTML = html;
                }
            }
        });
}

function shrinkStorage(target = 'agents', btn = null) {
    swal({ 
        title: "Optimize Storage?", 
        text: "This will shrink the storage container to the smallest safe size (Contents + 128MB headroom). Are you sure?", 
        type: "warning", 
        showCancelButton: true,
        showLoaderOnConfirm: true,
        closeOnConfirm: false
    }, function(isConfirm) {
        if (!isConfirm) return;
        const csrf = getCsrf();
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=shrink_storage&type=' + encodeURIComponent(target) + '&csrf_token=' + encodeURIComponent(csrf))
            .then(function(r) { return r.json(); })
            .then(function(data) { 
                if (data.status === 'error') {
                    swal("Error", data.message || "Failed to shrink storage.", "error");
                } else {
                    swal("Shrink Complete", data.message || "Storage optimized successfully.", "success");
                    refreshStorageStatus(); 
                }
            })
            .catch(function() {
                swal("Error", "Network error occurred while shrinking storage.", "error");
            });
    });
}

function expandStorage(target = 'agents', callback = null, btn = null) {
    const size = target === 'agents' ? '256MB' : '128MB';
    swal({ 
        title: "Expand Storage?", 
        text: "Increase storage capacity by " + size + "?", 
        type: "info", 
        showCancelButton: true,
        showLoaderOnConfirm: true,
        closeOnConfirm: false
    }, function(isConfirm) {
        if (!isConfirm) return;
        const csrf = getCsrf();
        fetch('/plugins/unraid-aicliagents/AICliAjax.php?action=expand_storage&type=' + encodeURIComponent(target) + '&csrf_token=' + encodeURIComponent(csrf))
            .then(function(r) { return r.json(); })
            .then(function(data) { 
                if (data.status === 'error') {
                    swal("Error", data.message || "Failed to expand storage.", "error");
                } else {
                    swal("Expand Complete", "Storage capacity increased by " + size, "success");
                    if (callback) callback(); 
                    refreshStorageStatus(); 
                }
            })
            .catch(function() {
                swal("Error", "Network error occurred while expanding storage.", "error");
            });
    });
}

setInterval(refreshStorageStatus, 3000); // D-170: Snappier refresh (3s)
</script>
