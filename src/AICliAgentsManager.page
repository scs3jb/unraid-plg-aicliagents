function toggleMigrateBtn(inputId, btnId, originalValue) {
    const input = document.getElementById(inputId);
    const btn = document.getElementById(btnId);
    if (!input || !btn) return;
    
    const isChanged = (input.value !== originalValue && input.value !== '');
    btn.disabled = !isChanged;
    if (isChanged) {
        btn.style.opacity = '1';
        btn.style.cursor = 'pointer';
    } else {
        btn.style.opacity = '0.5';
        btn.style.cursor = 'not-allowed';
    }
}

function refreshStorageStatus() {
    const csrf = getCsrf();
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=get_storage_status&csrf_token=${encodeURIComponent(csrf)}`)
        .then(r => r.json())
        .then(data => {
            const loading = document.getElementById('storage-status-loading');
            const active = document.getElementById('storage-status-active');
            if (data.status === 'mounted') {
                if (loading) loading.style.display = 'none';
                if (active) active.style.display = 'flex';
                
                const used = data.used_mb || 0;
                const logicalUsed = data.logical_used_mb || 0;
                const total = data.total_mb || 2048;
                const pct = Math.min(100, Math.round((used / total) * 100));
                const lpct = data.logical_pct || 0;
                
                const text = document.getElementById('storage-usage-text');
                const bar = document.getElementById('storage-usage-bar');
                const lbar = document.getElementById('storage-logical-bar');
                const headroom = document.getElementById('flash-headroom-text');
                const btn = document.getElementById('btn-expand-storage');
                
                // D-126: Support both '1.5x (60%)' from compsize or fallback formats
                let ratioStr = data.compression_ratio || '1.0x';
                if (!ratioStr.includes('x')) {
                    const ratioVal = parseInt(ratioStr);
                    ratioStr = (isNaN(ratioVal) || ratioVal >= 100 || ratioVal <= 0) ? '1.0x' : (Math.round((100 / ratioVal) * 10) / 10).toFixed(1) + 'x';
                }
                
                const ratioLabel = ` | ${ratioStr}`;
                const imgSizeStr = data.disk_size_mb ? ` [Disk: ${data.disk_size_mb}MB]` : '';
                const available = data.available_mb || 0;
                const effective = data.effective_available_mb || data.available_mb;
                const freeLabel = effective > 1024 ? (effective / 1024).toFixed(1) + 'GB' : effective + 'MB';
                const freeSuffix = effective !== available ? ' Free (Effective)' : ' Free';

                const logLabel = logicalUsed > 1024 ? (logicalUsed / 1024).toFixed(1) + 'GB' : logicalUsed + 'MB';
                const physLabel = used > 1024 ? (used / 1024).toFixed(1) + 'GB' : used + 'MB';
                const capacityLabel = total > 1024 ? (total / 1024).toFixed(1) + 'GB' : total + 'MB';
                const diskLabel = data.file_size_mb > 1024 ? (data.file_size_mb / 1024).toFixed(1) + 'GB' : data.file_size_mb + 'MB';
                const roBadge = data.is_read_only ? ' <span class="aicli-pill-btn" style="background:#444; cursor:default; padding:1px 6px; font-size:0.8em; margin-left:5px; box-shadow:none; text-transform:none;" title="Storage is mounted Read-Only for protection">READ-ONLY</span>' : '';

                if (text) {
                    text.innerHTML = `Contents: <span title="Uncompressed logical data size">${logLabel}</span>:<span title="Physical space used on disk">${physLabel}</span> <span style="opacity:0.6; font-size:0.9em;">(actual:comp)</span> Disk: <span title="Image File Size on Flash/Cache">${diskLabel}</span>${roBadge}`;
                }
                if (bar) {
                    bar.style.width = pct + '%';
                    bar.style.background = pct > 90 ? '#cc0000' : (pct > 75 ? '#ff8c00' : '#81b300');
                }
                if (lbar) {
                    lbar.style.width = lpct + '%';
                }

                // D-126: Update Rootfs (RAM Disk) stats on settings page
                if (data.rootfs_usage_percent !== undefined) {
                    const rText = document.getElementById('rootfs-usage-text');
                    const rBar = document.getElementById('rootfs-usage-bar');
                    const rWarn = document.getElementById('rootfs-warn-icon');
                    const rPct = data.rootfs_usage_percent;
                    
                    if (rText) rText.innerText = `${rPct}% Used (${data.rootfs_free_mb}MB Free)`;
                    if (rBar) {
                        rBar.style.width = rPct + '%';
                        rBar.style.background = rPct > 85 ? '#f87171' : (rPct > 60 ? '#fbbf24' : '#34d399');
                    }
                    if (rWarn) rWarn.style.display = data.rootfs_warning ? 'inline-block' : 'none';
                }
                
                if (btn) {
                    const isDisabled = data.flash_headroom_mb < 150;
                    btn.style.opacity = isDisabled ? '0.5' : '1';
                    btn.style.cursor = isDisabled ? 'not-allowed' : 'pointer';
                    btn.title = isDisabled ? 'Insufficient Flash space to expand' : 'Increase image size by 500MB';
                }

                // Render Home Storage Blocks
                if (data.home_stats) {
                    const homeContainer = document.getElementById('home_storage_container');
                    let html = '';
                    for (const user in data.home_stats) {
                        const stats = data.home_stats[user];
                        const hpct = stats.percent;
                        const hbg = hpct > 90 ? '#cc0000' : (hpct > 75 ? '#ff8c00' : '#86b32d');
                        const hLogLabel = stats.logical_used_mb > 1024 ? (stats.logical_used_mb / 1024).toFixed(1) + 'GB' : stats.logical_used_mb + 'MB';
                        const hPhysLabel = stats.used_mb > 1024 ? (stats.used_mb / 1024).toFixed(1) + 'GB' : stats.used_mb + 'MB';
                        const hDiskLabel = stats.disk_size_mb > 1024 ? (stats.disk_size_mb / 1024).toFixed(1) + 'GB' : stats.disk_size_mb + 'MB';

                        html += `
                            <div class="aicli-info-row">
                                <div class="aicli-info-label">Home: <b>${user}</b></div>
                                <div class="aicli-info-value" style="font-size:0.9em;">
                                    <div style="display:flex; flex-direction:column; gap:4px; width:100%;">
                                        <div style="display:flex; justify-content:space-between; align-items:center;">
                                            <code title="Logical: ${stats.logical_used_mb}MB, Physical: ${stats.used_mb}MB, Capacity: ${stats.total_mb}MB">Contents: ${hLogLabel}:${hPhysLabel} <span style="opacity:0.6; font-size:0.9em;">(actual:comp)</span> Disk: ${hDiskLabel}</code>
                                            <div class="aicli-info-btns">
                                                <span onclick="shrinkStorage('${user}')" class="aicli-pill-btn danger" title="Decrease image size by 128MB">-128MB</span>
                                                <span onclick="expandStorage('${user}')" class="aicli-pill-btn" title="Increase image size by 128MB">+128MB</span>
                                            </div>
                                        </div>
                                        <div style="height:6px; background:#333; border-radius:3px; overflow:hidden; position:relative;">
                                            <div style="height:100%; width:${stats.logical_pct}%; background:rgba(255,255,255,0.1); position:absolute; top:0; left:0; transition: width 0.4s ease;"></div>
                                            <div style="height:100%; width:${hpct}%; background:${hbg}; position:absolute; top:0; left:0; transition: width 0.4s ease;"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }
                    if (homeContainer) {
                        html += `
                            <div style="font-size: 11px; opacity: 0.5; margin-top: 15px; font-style: italic; border-top: 1px solid var(--border-color, #ccc); padding-top: 10px;">
                                * Disk usage reflects physical space consumed after Btrfs snapshots. FAT32 Flash drives do not support sparse files (Full Allocation); for maximum efficiency, move storage to an Array/Cache disk (XFS/Btrfs/ZFS).
                            </div>
                        `;
                        homeContainer.innerHTML = html;
                    }
                }
            } else {
                if (loading) loading.innerText = 'Storage Status: ' + (data.status || 'Unknown');
            }
        });
}

function shrinkStorage(target = 'agents') {
    if (typeof swal !== 'function') return;
    
    const inc = target === 'agents' ? '256MB' : '128MB';
    swal({
        title: "Shrink Storage?",
        text: "This will reduce the capacity of the " + target + " Btrfs image by " + inc + ". Ensure there is free space inside before continuing.",
        type: "warning",
        showCancelButton: true,
        confirmButtonText: "Shrink Now",
        closeOnConfirm: false,
        showLoaderOnConfirm: true
    }, function() {
        const csrf = getCsrf();
        fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=shrink_storage&type=${encodeURIComponent(target)}&csrf_token=${encodeURIComponent(csrf)}`)
            .then(r => r.json())
            .then(data => {
                if (data.status === 'ok') {
                    swal("Shrunk!", "Storage size decreased.", "success");
                    refreshStorageStatus();
                } else {
                    swal("Failed", data.message || "Failed to shrink. Clean unused data first.", "error");
                }
            })
            .catch(() => {
                swal("Error", "Network error.", "error");
            });
    });
}

function expandStorage(target = 'agents', callback = null) {
    console.log(`[AICli] Initiating expandStorage for: ${target}`);
    
    if (typeof swal !== 'function') return;
    
    const showLoading = !callback; // If we have a callback, the caller likely shows its own UI
    
    const executeExpansion = () => {
        const csrf = getCsrf();
        fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=expand_storage&type=${encodeURIComponent(target)}&csrf_token=${encodeURIComponent(csrf)}`)
            .then(r => r.json())
            .then(data => {
                if (data.status === 'ok') {
                    if (callback) {
                        callback();
                    } else {
                        const inc = target === 'agents' ? '256MB' : '128MB';
                        swal("Expanded!", "Storage container logical size increased by " + inc + ".", "success");
                    }
                    refreshStorageStatus();
                } else {
                    swal("Failed", data.message || "Manual expansion failed. Check Flash space.", "error");
                }
            })
            .catch(() => {
                swal("Network Error", "Could not reach the server.", "error");
            });
    };

    if (callback) {
        // No confirmation needed if triggered from a larger flow (like install recovery)
        executeExpansion();
    } else {
        const inc = target === 'agents' ? '256MB' : '128MB';
        swal({
            title: "Expand Storage?",
            text: "This will increase the capacity of the " + target + " Btrfs image by " + inc + ". This is nearly instant.",
            type: "info",
            showCancelButton: true,
            confirmButtonText: "Expand Now",
            closeOnConfirm: false,
            showLoaderOnConfirm: true
        }, function() {
            executeExpansion();
        });
    }
}

// D-88: Auto-refresh storage stats every 5 seconds while page is open
let storageInterval = setInterval(refreshStorageStatus, 5000);

// Close on unload
window.addEventListener('beforeunload', () => clearInterval(storageInterval));
</script>
