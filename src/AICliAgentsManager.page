                <div id="picker-path" class="aicli-modal-path">/mnt</div>
                <div id="picker-list" class="aicli-modal-list">
                    <!-- Items will be injected here -->
                </div>
            </div>
            <div class="aicli-modal-footer">
                <button type="button" class="aicli-modal-btn secondary" onclick="closePicker()">Cancel</button>
                <button type="button" class="aicli-modal-btn primary" onclick="confirmSelection()">Select Directory</button>
            </div>
        </div>
    </div>
</div>

<script>
// Use the PHP-parsed aicli_csrf token as the primary source of truth
window.csrf_token = window.csrf_token || '<?=$csrf_token?>';

function getCsrf() {
    return window.csrf_token || (typeof csrf_token !== 'undefined' ? csrf_token : '');
}

var codeAZ; // Polyfill for Dynamix shortcut handler (Andrew Zawadzki's codeAZ conflict)
var aicli_csrf = getCsrf();
var isInstalling = false; // Legacy flag, using activeInstalls now
var progressTimers = {};
var activeInstalls = new Set();
var isGlobalLocked = false;
var isUnloading = false;
window.addEventListener('beforeunload', () => { isUnloading = true; });

let currentPickerTarget = null;
let currentPickerPath = '/mnt';

function openPicker(targetId, startPath = null) {
    currentPickerTarget = targetId;
    const initialPath = startPath || document.getElementById(targetId).value || '/mnt';
    currentPickerPath = initialPath;
    
    document.getElementById('picker-modal').style.display = 'flex';
    browseTo(initialPath);
}

function closePicker() {
    document.getElementById('picker-modal').style.display = 'none';
}

function browseTo(path) {
    currentPickerPath = path;
    document.getElementById('picker-path').innerText = path;
    const list = document.getElementById('picker-list');
    list.innerHTML = '<div style="padding: 20px; text-align: center; opacity: 0.5;"><i class="fa fa-circle-o-notch fa-spin"></i> Reading...</div>';
    
    aicli_csrf = getCsrf();
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=list_dir&path=${encodeURIComponent(path)}&csrf_token=${encodeURIComponent(aicli_csrf)}`)
        .then(r => r.json())
        .then(data => {
            list.innerHTML = '';
            
            // Add items
            data.items.forEach(item => {
                const div = document.createElement('div');
                div.className = 'aicli-modal-item';
                div.onclick = () => browseTo(item.path);
                
                const icon = item.name === '..' ? 'fa-level-up' : 'fa-folder';
                div.innerHTML = `<i class="fa ${icon}"></i> <span>${item.name}</span>`;
                list.appendChild(div);
            });
            
            if (data.items.length === 0) {
                list.innerHTML = '<div style="padding: 20px; text-align: center; opacity: 0.3;">Empty Directory</div>';
            }
        })
        .catch(err => {
            list.innerHTML = `<div style="padding: 20px; text-align: center; color: #ff5555;">Error: ${err.message}</div>`;
        });
}

function confirmSelection() {
    if (currentPickerTarget) {
        document.getElementById(currentPickerTarget).value = currentPickerPath;
    }
    closePicker();
}

function openCreateUserModal() {
    window.open('/Users/UserAdd', '_blank');
}

function refreshUserList() {
    aicli_csrf = getCsrf();
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=get_users&csrf_token=${encodeURIComponent(aicli_csrf)}`)
        .then(r => r.json())
        .then(data => {
            if (data.status === 'ok' && data.users) {
                const select = document.getElementById('user_select');
                const currentVal = select.value;
                select.innerHTML = '';
                Object.entries(data.users).forEach(([u, d]) => {
                    const opt = document.createElement('option');
                    opt.value = u;
                    opt.innerText = u + (d && u !== d ? ` (${d})` : "");
                    select.appendChild(opt);
                });
                select.value = currentVal; // Preserve selection
                onUserChange(currentVal);
            }
        });
}

function onUserChange(username) {
    // Dynamically update UI paths to show user what will happen on save
    const ramDisplay = document.getElementById('display_ram_dir');
    const homeInput = document.getElementById('home_path');
    const homeDisplay = document.getElementById('display_home_path');
    
    if (ramDisplay) ramDisplay.innerText = `/tmp/unraid-aicliagents/work/${username}`;
    if (homeInput) homeInput.value = `/boot/config/plugins/unraid-aicliagents/persistence/${username}/home`;
    if (homeDisplay) homeDisplay.innerText = `/boot/config/plugins/unraid-aicliagents/persistence/${username}/home`;
}

function checkUpdates() {
    if (activeInstalls.size > 0) return;
    const btn = document.getElementById('btn-check-updates');
    console.log("[AICli] Checking for updates...");
    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-circle-o-notch fa-spin"></i> Checking...';

    aicli_csrf = getCsrf();
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=check_updates&csrf_token=${encodeURIComponent(aicli_csrf)}`)
        .then(r => r.json())
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-refresh"></i> Check for Updates';
            
            if (data.status === 'ok' && data.updates) {
                Object.entries(data.updates).forEach(([id, info]) => {
                    const status = document.getElementById(`status-${id}`);
                    if (status && info.has_update) {
                        status.className = 'agent-status update';
                        status.innerHTML = `<i class="fa fa-arrow-circle-up"></i> Update Available (${info.latest_version})`;
                    }
                });
            }
        })
        .catch(err => {
            console.error(err);
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-refresh"></i> Check for Updates';
        });
}

function viewDebugLog() {
    aicli_csrf = getCsrf();
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=get_log&csrf_token=${encodeURIComponent(aicli_csrf)}`)
        .then(r => r.text())
        .then(text => {
            if (typeof swal === 'function') {
                swal({
                    title: "Debug Log (Last 50 lines)",
                    text: text || "Log is empty.",
                    customClass: "swal-wide"
                });
            }
        });
}

function manualSyncHome() {
    aicli_csrf = getCsrf();
    const btn = event.currentTarget;
    const originalHtml = btn.innerHTML;
    
    // Show non-closable overlay
    if (typeof swal === 'function') {
        swal({
            title: "Syncing to Flash...",
            text: "Mirroring RAM home directory to the USB drive. This may take a few moments depending on the amount of data.",
            type: "info",
            showConfirmButton: false,
            closeOnConfirm: false
        });
    }

    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-circle-o-notch fa-spin"></i> Syncing...';

    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=sync_home&csrf_token=${encodeURIComponent(aicli_csrf)}`)
        .then(r => {
            if (!r.ok) throw new Error(`HTTP error! status: ${r.status}`);
            return r.text().then(text => {
                try {
                    return JSON.parse(text);
                } catch (e) {
                    console.error("[AICli] Failed to parse sync response:", text);
                    throw new Error("Invalid JSON response from server");
                }
            });
        })
        .then(data => {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            if (data.status === 'ok') {
                if (typeof swal === 'function') {
                    swal({
                        title: "Sync Successful",
                        text: "Home directory contents have been mirrored to the USB Flash drive.",
                        type: "success",
                        confirmButtonText: "Close"
                    });
                }
            } else {
                if (typeof swal === 'function') {
                    swal("Sync Failed", "There was an error syncing to flash. Check debug logs.", "error");
                }
            }
        })
        .catch(err => {
            console.error(err);
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            if (typeof swal === 'function') {
                swal("Sync Error", "Network or server error during sync.", "error");
            }
        });
}

function clearLog() {
    swal({
        title: "Clear debug log?",
        text: "This will truncate the current debug.log file in RAM.",
        type: "warning",
        showCancelButton: true,
        confirmButtonText: "Clear Log",
        cancelButtonText: "Cancel",
        closeOnConfirm: false
    }, function() {
        aicli_csrf = getCsrf();
        fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=clear_log&csrf_token=${encodeURIComponent(aicli_csrf)}`)
            .then(r => r.json())
            .then(data => {
                if (data.status === 'ok') {
                    swal("Log Cleared", "The debug log has been truncated.", "success");
                } else {
                    swal("Error", "Failed to clear log: " + (data.message || 'Unknown error'), "error");
                }
            })
            .catch(() => {
                swal("Error", "Network error while clearing log.", "error");
            });
    });
}



function setAgentStoreLocked(locked) {
    isGlobalLocked = locked;
    // We only disable buttons if we reach a certain limit or if we want to prevent UNINSTALLS during installs.
    // For now, let's keep it fluid.
}

function pollInstallStatus(agentId) {
    aicli_csrf = getCsrf();
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=get_install_status&agentId=${agentId}&csrf_token=${encodeURIComponent(aicli_csrf)}`)
        .then(r => r.json())
        .then(data => {
            const textEl = document.getElementById(`text-${agentId}`);
            const barEl = document.getElementById(`bar-${agentId}`);
            const statusEl = document.getElementById(`status-${agentId}`);
            const btnInstall = document.getElementById(`btn-install-${agentId}`);
            const btnUpgrade = document.getElementById(`btn-upgrade-${agentId}`);

            if (data.message) {
                if (textEl) textEl.innerText = data.message;
                if (barEl) barEl.style.width = data.progress + '%';
            }
            
            if (data.progress >= 100) {
                clearInterval(progressTimers[agentId]);
                delete progressTimers[agentId];
                activeInstalls.delete(agentId);
                
                if (statusEl) {
                    statusEl.className = 'agent-status installed';
                    statusEl.innerHTML = '<i class="fa fa-check-circle"></i> ' + (data.message || 'Installed');
                }
                
                // Only reload if this was the last active install
                if (activeInstalls.size === 0) {
                    setTimeout(() => { if (!isUnloading) window.location.reload(); }, 2000);
                }
            } else if (data.message && data.message.includes('Error:')) {
                clearInterval(progressTimers[agentId]);
                delete progressTimers[agentId];
                activeInstalls.delete(agentId);
                if (btnInstall) btnInstall.disabled = false;
                if (btnUpgrade) btnUpgrade.disabled = false;
            }
        })
        .catch(err => {
            if (isUnloading) return;
            console.error(`[AICli] Poll Error for ${agentId}:`, err);
        });
}

function installAgent(agentId, isUpgrade = false, btn = null) {
    if (activeInstalls.has(agentId)) return;
    
    if (isUpgrade) {
        swal({
            title: "Upgrade Agent?",
            text: `Confirm upgrading ${agentId} to the latest version.`,
            type: "info",
            showCancelButton: true,
            confirmButtonText: "Upgrade Now",
            cancelButtonText: "Cancel"
        }, function(confirmed) {
            if (confirmed) {
                performAgentInstall(agentId, isUpgrade, btn);
            }
        });
    } else {
        performAgentInstall(agentId, isUpgrade, btn);
    }
}

function performAgentInstall(agentId, isUpgrade, btn) {
    
    const status = document.getElementById(`status-${agentId}`);
    const progress = document.getElementById(`progress-${agentId}`);
    const bar = document.getElementById(`bar-${agentId}`);
    const text = document.getElementById(`text-${agentId}`);
    
    // Disable the button which was clicked
    if (btn) btn.disabled = true;

    progress.style.display = 'block';
    bar.style.width = '10%';
    if (text) text.innerText = 'Starting...';
    status.innerHTML = '<i class="fa fa-circle-o-notch fa-spin"></i> ' + (isUpgrade ? 'Upgrading...' : 'Installing...');

    aicli_csrf = getCsrf();
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=install_agent&agentId=${agentId}&csrf_token=${encodeURIComponent(aicli_csrf)}`)
        .then(r => r.json())
        .then(data => {
            if (data.status === 'ok') {
                if (progressTimers[agentId]) clearInterval(progressTimers[agentId]);
                progressTimers[agentId] = setInterval(() => pollInstallStatus(agentId), 800);
            } else {
                activeInstalls.delete(agentId);
                if (btn) btn.disabled = false;
                swal("Installation Failed", (data.message || data.error), "error");
                status.innerHTML = 'Start Failed';
            }
        })
        .catch(err => {
            if (isUnloading) return;
            activeInstalls.delete(agentId);
            if (btn) btn.disabled = false;
            console.error('[AICli] Start Error:', err);
            swal("Network Error", "Process might still be starting in background.", "warning");
        });
}

function uninstallAgent(agentId, btn = null) {
    if (activeInstalls.has(agentId)) return;
    
    swal({
        title: "Uninstall Agent?",
        text: `Are you sure you want to remove ${agentId}? All associated data and configurations for this agent will be purged.`,
        type: "warning",
        showCancelButton: true,
        confirmButtonColor: "#DD6B55",
        confirmButtonText: "Yes, Uninstall",
        cancelButtonText: "Cancel"
    }, function(confirmed) {
        if (confirmed) {
            activeInstalls.add(agentId);
            if (btn) btn.disabled = true;

            aicli_csrf = getCsrf();
            fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=uninstall_agent&agentId=${agentId}&csrf_token=${encodeURIComponent(aicli_csrf)}`)
                .then(r => r.json())
                .then(data => {
                    if (data.status === 'ok') {
                        window.location.reload();
                    } else {
                        activeInstalls.delete(agentId);
                        if (btn) btn.disabled = false;
                        swal("Uninstall Failed", (data.message || data.error), "error");
                    }
                })
                .catch(err => {
                    if (isUnloading) return;
                    activeInstalls.delete(agentId);
                    if (btn) btn.disabled = false;
                    console.error(err);
                    swal("Network Error", "Check console for details.", "error");
                });
        }
    });
}

function saveAICliAgentsManager(form, silent = false) {
    const formData = new FormData(form);
    const params = new URLSearchParams();
    
    // Deduplicate aicli_csrf and other keys
    for (const [key, value] of formData.entries()) {
        params.set(key, value); 
    }
    
    // Ensure we use the latest system aicli_csrf token if Dynamix has provided one
    aicli_csrf = getCsrf() || formData.get('csrf_token') || '';
    params.set('csrf_token', aicli_csrf);
    
    // D-18: Collect all preview checkboxes (they may be outside the main settings form)
    document.querySelectorAll('input[type="checkbox"][name^="preview_"]').forEach(cb => {
        params.set(cb.name, cb.checked ? "1" : "0");
    });
    
    console.log('[AICli] Saving settings (deduplicated):', params.toString());

    const performSave = (callback) => {
        fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=save&csrf_token=${encodeURIComponent(aicli_csrf)}`, {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: params.toString()
        })
        .then(r => {
            if (!r.ok) {
                return r.text().then(txt => {
                    console.error('[AICli] Server Error (HTTP ' + r.status + '):', txt);
                    throw new Error('Server returned ' + r.status);
                });
            }
            return r.json();
        })
        .then(data => {
            console.log('[AICli] Save response:', data);
            if (data.status === 'ok' && callback) callback();
            else if (data.status === 'ok' && !silent) {
                if (typeof swal === 'function') {
                    swal({
                        title: "Settings Saved",
                        text: "Changes applied. Some settings may require a terminal restart. Restart now?",
                        type: "success",
                        showCancelButton: true,
                        confirmButtonText: "Restart Terminal",
                        cancelButtonText: "Later"
                    }, function(confirmed) {
                        if (confirmed) {
                            fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=restart&csrf_token=${encodeURIComponent(aicli_csrf)}`)
                            .then(() => window.location.reload());
                        } else {
                            window.location.reload();
                        }
                    });
                } else {
                    window.location.reload();
                }
            } else if (data.status === 'ok' && silent) {
                window.location.reload();
            } else {
                swal("Save Failed", (data.message || 'Unknown error'), "error");
            }
        })
        .catch(err => {
            console.error("[AICli] Save Error:", err);
            swal("Network Error", "Settings failed to save. See console for details.", "error");
        });
    };

    performSave();
}

// Auto-check for updates on page load
document.addEventListener('DOMContentLoaded', () => {
aicli_csrf = getCsrf();
// Check for any ongoing installs across all agents
document.querySelectorAll('.agent-actions').forEach(container => {
    const id = container.id.replace('actions-', '');
    if (!id) return;
    
    fetch(`/plugins/unraid-aicliagents/AICliAjax.php?action=get_install_status&agentId=${id}&csrf_token=${encodeURIComponent(aicli_csrf)}`)
        .then(r => r.json())
        .then(data => {
            if (data.progress > 0 && data.progress < 100) {
                const status = document.getElementById(`status-${id}`);
                const progress = document.getElementById(`progress-${id}`);
                const bar = document.getElementById(`bar-${id}`);
                const text = document.getElementById(`text-${id}`);
                
                if (status && progress) {
                    activeInstalls.add(id);
                    status.innerHTML = '<i class="fa fa-circle-o-notch fa-spin"></i> Resuming...';
                    progress.style.display = 'block';
                    bar.style.width = data.progress + '%';
                    if (text) text.innerText = data.message || 'Resuming...';
                    
                    if (progressTimers[id]) clearInterval(progressTimers[id]);
                    progressTimers[id] = setInterval(() => pollInstallStatus(id), 800);
                }
            }
        });
});

setTimeout(checkUpdates, 1000);
});
</script>
