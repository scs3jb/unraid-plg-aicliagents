<style>
/* 
   SCORCHED EARTH on scrollbars. 
   We force hidden on EVERY potential parent wrapper.
*/
/* 
   SUPER-NUCLEAR reset for scrollbars and gutters.
   We force hidden/clip on EVERYTHING that could reserve space.
*/
html,
body, 
#displaybox, 
#sb-body, 
#sb-container,
.gemini-ui, 
main, 
