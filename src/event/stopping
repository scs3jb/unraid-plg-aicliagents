#!/bin/bash
# AI CLI Agents: Shutdown/Array Stop persistence sync
# D-170: Pivot to centralized stop-plugin.sh for unified unmounts & sync.

EMHTTP_DEST="/usr/local/emhttp/plugins/unraid-aicliagents"
LOG="/tmp/unraid-aicliagents/debug.log"

echo "[$(date '+%Y-%m-%d %H:%M:%S')] [EVENT-STOPPING] Shutdown detected. Calling stop sequence..." >> "$LOG"

if [ -f "$EMHTTP_DEST/scripts/user/stop-plugin.sh" ]; then
    bash "$EMHTTP_DEST/scripts/user/stop-plugin.sh"
else
    # Fallback if centralized script is missing
    /usr/bin/php -r "require_once '$EMHTTP_DEST/includes/AICliAgentsManager.php'; aicli_sync_all();"
fi

echo "[$(date '+%Y-%m-%d %H:%M:%S')] [EVENT-STOPPING] Stop sequence complete." >> "$LOG"
