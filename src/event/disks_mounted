#!/bin/bash
# AICliAgents: Array Start Restoration
# Fires when Unraid disks are mounted (array started).
# Cleans up emergency mode, restarts sync daemon, and publishes UI refresh.

EMHTTP_DEST="/usr/local/emhttp/plugins/unraid-aicliagents"
LOG="/tmp/unraid-aicliagents/debug.log"

mkdir -p /tmp/unraid-aicliagents

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [INFO] [EventDisksMounted] $1" >> "$LOG"
}

log "Array disks mounted. Checking for deferred storage restoration..."

# 1. Clean up emergency mode if active
if [ -f /tmp/unraid-aicliagents/.emergency_mode ]; then
    log "Emergency mode detected. Cleaning up and restoring normal operation..."

    # Kill emergency terminal sessions
    if command -v tmux >/dev/null 2>&1; then
        tmux ls -F '#S' 2>/dev/null | grep -E '^aicli-agent-' | xargs -I {} tmux kill-session -t {} >/dev/null 2>&1
    fi
    pkill -f 'ttyd.*(aicliterm|temp-terminal)-' >/dev/null 2>&1

    # Remove emergency home and flag
    rm -rf /tmp/unraid-aicliagents/emergency_home
    rm -f /tmp/unraid-aicliagents/.emergency_mode

    # Remove any symlinks to emergency home in work dirs
    for link in /tmp/unraid-aicliagents/work/*/home; do
        [ -L "$link" ] && rm -f "$link"
    done

    # Remove emergency-installed agents from RAM
    AGENT_BASE="/usr/local/emhttp/plugins/unraid-aicliagents/agents"
    for flag in /tmp/unraid-aicliagents/.emergency_agent_*; do
        [ -f "$flag" ] || continue
        eid="${flag##*.emergency_agent_}"
        edir="$AGENT_BASE/$eid"
        if [ -d "$edir" ] && ! mountpoint -q "$edir" 2>/dev/null; then
            rm -rf "$edir"
            log "Removed emergency RAM agent: $eid"
        fi
        rm -f "$flag"
    done

    log "Emergency mode cleaned up."
fi

# 2. Restart sync daemon and publish UI refresh (delegate to PHP for config awareness)
if [ -f "$EMHTTP_DEST/src/includes/AICliAgentsManager.php" ]; then
    timeout 30 /usr/bin/php -r "
        require_once '$EMHTTP_DEST/src/includes/AICliAgentsManager.php';
        \$config = getAICliConfig();
        \$persistPath = \$config['agent_storage_path'] ?? '/boot/config/plugins/unraid-aicliagents';
        if (\AICliAgents\Services\StorageMountService::isPathAvailable(\$persistPath)) {
            aicli_log('disks_mounted: Storage path available. Restarting sync daemon.', AICLI_LOG_INFO, 'EventDisks');
            \$username = \$config['user'] ?? 'root';
            if (\$username === '0') \$username = 'root';
            \AICliAgents\Services\TaskService::manageSyncDaemon(\$username, true);
            // Notify UI to refresh
            \AICliAgents\Services\NchanService::publish('storage_status', aicli_get_storage_status());
        } else {
            aicli_log('disks_mounted: Storage path still not available. Will retry on next access.', AICLI_LOG_WARN, 'EventDisks');
        }
    " >> "$LOG" 2>&1
fi

log "Restoration sequence complete."
